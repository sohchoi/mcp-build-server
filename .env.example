# MCP Build Server environment configuration
# Copy this file to .env and fill in the values

# Port the HTTP server listens on
PORT=8080

# Base directory where your git repos live on this VDI
REPOS_BASE_DIR=D:\

# Secret token — must match X-Webhook-Secret header in the pre-push hook
WEBHOOK_SECRET=change-me-to-something-random

# Max number of builds to keep per repo in builds.json
MAX_BUILDS_PER_REPO=20

# Branch synchronization window (pre-push race mitigation):
# Wait up to (REMOTE_BRANCH_WAIT_ATTEMPTS * REMOTE_BRANCH_WAIT_DELAY_MS)
# for the pushed branch to appear on origin before starting fetch/build.
REMOTE_BRANCH_WAIT_ATTEMPTS=60
REMOTE_BRANCH_WAIT_DELAY_MS=2000

# Additional fetch retry window after branch appears on origin.
FETCH_BRANCH_MAX_ATTEMPTS=20
FETCH_BRANCH_RETRY_DELAY_MS=3000

# Build scope (IMPORTANT):
# - related (Recommended): build only solutions related to changed paths
# - all: build all .sln files in repo (may fail on broken solutions)
BUILD_SCOPE=related

# Optional: Explicit path to MSBuild.exe.
# Leave empty to auto-detect via vswhere (requires Visual Studio).
# Example:
# MSBUILD_PATH=C:\Program Files\Microsoft Visual Studio\2022\Professional\MSBuild\Current\Bin\MSBuild.exe
MSBUILD_PATH=
