# MCP Build Server environment configuration
# Copy this file to .env and fill in the values

# Port the HTTP server listens on
PORT=3333

# Base directory where your git repos live on this VDI
REPOS_BASE_DIR=D:\

# Secret token — must match X-Webhook-Secret header in the post-push hook
WEBHOOK_SECRET=change-me-to-something-random

# Max number of builds to keep per repo in builds.json
POLL_INTERVAL_MS=30000
