# MCP Build Server environment configuration
# Copy this file to .env and fill in the values

# Port the HTTP server listens on
PORT=8080

# Base directory where your git repos live on this VDI
REPOS_BASE_DIR=D:\

# Secret token — must match X-Webhook-Secret header in the pre-push hook
WEBHOOK_SECRET=change-me-to-something-random

# Max number of builds to keep per repo in builds.json
MAX_BUILDS_PER_REPO=20

# Optional: Explicit MSBuild Visual Studio tools path used when MSB4019
# (missing Microsoft.WebApplication.targets) is detected.
# Example:
# VSTOOLS_PATH=C:\Program Files (x86)\MSBuild\Microsoft\VisualStudio\v17.0
VSTOOLS_PATH=
